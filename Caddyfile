# Caddy 配置文件 - AssppWeb 生产部署
# 支持 Cloudflare 代理 + DNS 验证 + Xray 代理路由

# 主域名配置
# 从环境变量 APP_DOMAIN 读取域名
{$APP_DOMAIN} {
  # ========================================
  # AdGuard Home (WireGuard DNS) 路由
  # ========================================

  # DoH: https://<域名>/dns-query
  handle /dns-query* {
    reverse_proxy wireguard-dns:3001
  }

  # 管理界面: https://<域名>/adguardhome
  handle_path /adguardhome* {
    reverse_proxy wireguard-dns:3000
  }

  # ========================================
  # Xray 代理路由配置
  # ========================================
  
  # 方式1: WebSocket 路径转发 (vless/vmess + ws)
  # Xray 客户端路径配置示例: "/ws" 或 "/proxy"
  handle /ws {
    reverse_proxy xray:10000 {
      # WebSocket 升级支持
      header_up Connection "Upgrade"
      header_up Upgrade "websocket"
      # 保留原始 Host
      header_up Host {host}
      # 传递真实 IP
      header_up X-Real-IP {remote}
      header_up X-Forwarded-For {remote}
      header_up X-Forwarded-Proto {scheme}
    }
  }
  
  # 方式2: gRPC 转发 (vless/vmess + grpc)
  # Xray 客户端 serviceName 配置示例: "proxy"
  handle /proxy/* {
    reverse_proxy xray:10001 {
      # gRPC 需要 HTTP/2
      transport http {
        versions h2c
      }
      # 保留 gRPC 超时设置
      flush_interval -1
    }
  }
  
  # 方式3: XHTTP (SplitHTTP) 转发 - Xray 新版特性
  handle /xh* {
    reverse_proxy xray:10002 {
      header_up Host {host}
      header_up X-Real-IP {remote}
    }
  }
  
  # 方式4: 使用自定义路径转发 (根据你的 Xray 配置调整)
  # handle /your-custom-path {
  #   reverse_proxy xray:PORT {
  #     header_up Connection "Upgrade"
  #     header_up Upgrade "websocket"
  #   }
  # }

  # ========================================
  # AssppWeb 主应用路由
  # ========================================
  
  # 反向代理到后端应用
  reverse_proxy asspp:8080 {
    # 对 API 响应禁用缓存
    header_down Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
    header_down Pragma "no-cache"
    header_down Expires "0"
  }

  # 请求日志
  log {
    format json
    output stdout
  }

  # 安全头
  header {
    # HTTPS 强制
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # 防止 MIME 嗅探
    X-Content-Type-Options "nosniff"

    # XSS 保护
    X-Frame-Options "SAMEORIGIN"
    X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Referrer-Policy "strict-origin-when-cross-origin"
  }

  # GZIP 压缩 (注意: 如果 Xray 使用 WebSocket/XHTTP，建议对代理路径禁用)
  encode gzip

  # TLS 配置 - Cloudflare DNS 验证
  tls {
    dns cloudflare {env.CF_API_TOKEN}
  }
}

# 配置说明：
#
# 1. 环境变量配置
#    - APP_DOMAIN: 在 .env 文件中设置你的域名 (如 example.com)
#    - CF_API_TOKEN: 在 .env 文件中设置你的 Cloudflare API Token
#
# 2. Caddyfile 中的环境变量语法
#    - {$ENV_VAR_NAME} 用于读取环境变量
#    - {env.ENV_VAR_NAME} 用于在 tls 块中访问环境变量
#
# 3. 如何获取 Cloudflare API Token
#    a) 登录 Cloudflare Dashboard: https://dash.cloudflare.com/
#    b) 进入 "我的资料" → "API 令牌"
#    c) 创建令牌，权限选择：Zone > Zone > Read + Zone > DNS > Edit
#    d) 复制生成的 token，添加到 .env 文件中
#
# 4. .env 文件示例
#    APP_DOMAIN=itunes.example.com
#    CF_API_TOKEN=your_actual_cloudflare_token_here
#    ACME_AGREE=true
#
# 5. Cloudflare 代理设置
#    - 在 Cloudflare Dashboard 中，DNS 记录可以保持"已代理"状态（橙色云）
#    - Caddy 会通过 DNS 验证，无需 HTTP 验证
#    - Let's Encrypt 可以直接验证你的域名所有权
#
# 6. 证书自动续签
#    - Caddy 会自动在证书过期前 30 天续签
#    - DNS 验证会自动进行，无需手动干预
#
# 7. 日志查看
#    - docker-compose logs -f caddy
#
# 8. 证书状态
#    - docker exec <caddy-container-id> caddy list-json tls-certs
