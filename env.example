# Cloudflare API Token 用于 DNS 验证
# 获取方式：https://dash.cloudflare.com/profile/api-tokens
# 需要权限：Zone.Zone.Read + Zone.DNS.Edit
CF_API_TOKEN=your_actual_token_here

# 主应用域名
APP_DOMAIN=your_domain_here

# TrustTunnel VPN 配置
# TrustTunnel 将使用 Caddy 自动获取的 Let's Encrypt 证书
TRUSTTUNEL_DOMAIN=your_domain_here
TRUSTTUNEL_USERNAME=your_username
TRUSTTUNEL_PASSWORD=your_secure_password

# Snell 代理配置
SNELL_PORT=random_port
SNELL_PSK=random_psk
